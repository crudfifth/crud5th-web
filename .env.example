# ======================
# Environment Variables
# ======================

# Application Environment
NODE_ENV=development

# Server Configuration
PORT=5000

# Database Configuration
# PostgreSQL database connection URL
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/crud5th_db

# Email Configuration (if using server-side email)
# SENDGRID_API_KEY=your_sendgrid_api_key_here
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your_email@example.com
# SMTP_PASS=your_email_password

# External Service APIs (if needed)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token

# Development URLs (automatically set by Replit)
# REPLIT_DEV_DOMAIN=your-repl-name.replit.dev
# REPL_ID=your-repl-id
# REPL_OWNER=your-username